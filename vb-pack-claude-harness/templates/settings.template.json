{
  "_comment": "Template for .claude/settings.local.json. Copy to .claude/ via scripts/harness/bootstrap.py.",
  "permissions": {
    "allow": [
      "Bash(chmod +x .claude/hooks/*.py)",
      "Bash(chmod +x scripts/harness/*.py)",
      "Bash(python3 -m py_compile scripts/harness/*.py)",
      "Bash(python3 scripts/harness/self_test.py)",
      "Bash(python3 scripts/harness/event_log.py:*)",
      "Bash(python3 scripts/harness/learning_log.py:*)",
      "Bash(python3 scripts/harness/meta_supervisor.py:*)",
      "Bash(python3 scripts/harness/rotate_logs.py)",
      "Bash(python3 scripts/harness/hook_health.py:*)",
      "Bash(python3 -m unittest discover -s tests -v)",
      "Bash(python3 -m unittest discover -s tests -q)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.claude/hooks/session_start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.claude/hooks/user_prompt_submit.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.claude/hooks/pre_tool_use.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.claude/hooks/post_tool_use.py\"",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.claude/hooks/stop.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
